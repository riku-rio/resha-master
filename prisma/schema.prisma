generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model BotInstance {
  id          String    @id @default(cuid())
  botName     String    @unique
  botToken    String
  botId       String    @unique
  guildId     String
  templateId  String
  buyerId     String
  prefix      String    @default("!")
  status      BotStatus @default(STOPPED)
  subscriptionExpiresAt  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum BotStatus {
  RUNNING
  STOPPED
  EXPIRED
}